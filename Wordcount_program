1) download given dataset and name as data.txt:

file = open("data.txt", "r", encoding="utf-8")
text = file.read()
words = text.split()
word_count = {}
for word in words:
    word_count[word] = word_count.get(word, 0) + 1
for word, count in word_count.items():
    print(word, ":", count)


2) Using given sample text data :

text_data = [
    "Hello world",
    "Hello from the other side",
    "world of MapReduce",
    "MapReduce is powerful"
]

word_count = {}

for sentence in text_data:
    words = sentence.split()

    for word in words:
        word_count[word] = word_count.get(word, 0) + 1

for word, count in word_count.items():
    print(word, ":", count)
